# ----------------------------------------------------------
# APPLICATION
# ----------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="Aone Digital India"
NEXT_PUBLIC_SITE_DESCRIPTION="Your Trusted Mobile Phones & Home Appliances Destination"

# ----------------------------------------------------------
# EMAIL (Resend)
# ----------------------------------------------------------
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=info@aonedigitalindia.com
EMAIL_TO_ADMIN=info@aonedigitalindia.com
EMAIL_TO_SUPPORT=support@aonedigitalindia.com
EMAIL_REPLY_TO=info@aonedigitalindia.com

# ----------------------------------------------------------
# GOOGLE ANALYTICS
# ----------------------------------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ----------------------------------------------------------
# GOOGLE MAPS
# ----------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
NEXT_PUBLIC_STORE_LAT=XX.XXXX
NEXT_PUBLIC_STORE_LNG=XX.XXXX
NEXT_PUBLIC_MAPS_EMBED_URL=https://www.google.com/maps/embed?pb=...

# ----------------------------------------------------------
# CONTACT INFORMATION
# ----------------------------------------------------------
NEXT_PUBLIC_PHONE_NUMBER=+91XXXXXXXXXX
NEXT_PUBLIC_WHATSAPP_NUMBER=91XXXXXXXXXX
NEXT_PUBLIC_EMAIL=info@aonedigitalindia.com
NEXT_PUBLIC_SUPPORT_EMAIL=support@aonedigitalindia.com
NEXT_PUBLIC_STORE_ADDRESS="[Store Address Placeholder], [City], [State] - [PIN]"

# ----------------------------------------------------------
# SOCIAL MEDIA
# ----------------------------------------------------------
NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/aonedigitalindia
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/aonedigitalindia
NEXT_PUBLIC_YOUTUBE_URL=https://www.youtube.com/@aonedigitalindia
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/aonedigitalindia

# ----------------------------------------------------------
# RATE LIMITING (Upstash Redis — Optional)
# ----------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ----------------------------------------------------------
# ADMIN / SECURITY
# ----------------------------------------------------------
ADMIN_API_KEY=your_secure_random_admin_key_here
NEXTAUTH_SECRET=your_nextauth_secret_here

# ----------------------------------------------------------
# FEATURE FLAGS
# ----------------------------------------------------------
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_COOKIE_CONSENT=true
NEXT_PUBLIC_MAINTENANCE_MODE=false
NEXT_PUBLIC_ENABLE_DARK_MODE=true
